<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.example.artemisia</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>/Users/YOURUSER/Apps/artemisia/app.py</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/YOURUSER/Apps/artemisia</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/artemisia.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/artemisia.err</string>
</dict>
</plist>
